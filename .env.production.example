# ===========================================
# TL EM PAR — Variáveis de Produção
# Copie para .env e preencha os valores reais
# ===========================================

# ---- Banco de Dados ----
DB_USER=tlempar
DB_PASSWORD=GERE_UMA_SENHA_FORTE_AQUI

# ---- JWT (gere com: openssl rand -base64 64) ----
JWT_SECRET=GERE_UMA_CHAVE_SECRETA_AQUI
JWT_REFRESH_SECRET=GERE_OUTRA_CHAVE_SECRETA_AQUI
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_sua_chave_aqui
STRIPE_WEBHOOK_SECRET=whsec_seu_webhook_secret_aqui
STRIPE_PRICE_ID=price_seu_price_id_aqui
