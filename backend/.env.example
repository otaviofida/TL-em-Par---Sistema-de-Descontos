# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tlempar?schema=public"

# Server
PORT=3333
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_ID=price_your_default_price_id

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Stripe Redirect URLs
STRIPE_SUCCESS_URL=http://localhost:5173/assinatura/sucesso
STRIPE_CANCEL_URL=http://localhost:5173/assinatura/cancelado
